# 服务器配置
PORT=8002
DEBUG=false

# API 配置
# ⚠️ 仅供本地开发，生产环境请务必修改默认 API_KEY！
API_KEY=0000

# 逗号分隔的支持模型列表。第一项通常作为默认 / 推荐模型。
MODELS=claude-sonnet-4.6,claude-sonnet-4-5-20250929,claude-sonnet-4-20250514,claude-3-5-sonnet-20241022

# 追加到有效 system prompt 的额外指令（可留空）
SYSTEM_PROMPT_INJECT=

# 请求配置
TIMEOUT=60
MAX_INPUT_LENGTH=200000

# 代理配置 (可选, 支持 http/https/socks5)
# PROXY=http://127.0.0.1:7890
# PROXY=socks5://127.0.0.1:1080

# 浏览器指纹配置
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/140.0.0.0 Safari/537.36

# Vision / OCR 配置
VISION_ENABLED=false
VISION_MODE=ocr
VISION_LANGUAGES=eng,chi_sim
VISION_BASE_URL=https://api.openai.com/v1/chat/completions
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini

# Anthropic thinking 模式是“请求级参数”，不是环境变量。
# 请求体示例：
# "thinking": {"type": "enabled", "budget_tokens": 2048}
